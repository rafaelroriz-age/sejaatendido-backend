{
  "name": "backend-sejaatendido",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "prisma generate && tsc",
    "start": "DIRECT_URL=${DIRECT_URL:-$DATABASE_URL} npx prisma migrate deploy || echo '⚠️  prisma migrate deploy falhou — servidor sobe mesmo assim'; node dist/index.js",
    "start:local": "node dist/index.js",
    "seed": "ts-node src/seed.ts",
    "test": "NODE_ENV=test NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "migrate": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.1",
    "firebase-admin": "^13.6.0",
    "google-auth-library": "^10.3.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "mercadopago": "^2.12.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.11",
    "prisma": "^5.22.0",
    "qrcode-terminal": "^0.12.0",
    "winston": "^3.13.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
