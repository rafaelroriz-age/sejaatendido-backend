generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senhaHash String
  tipo      TipoUsuario
  emailConfirmado Boolean @default(false)
  emailVerificacaoTokenHash String?
  emailVerificacaoExpiraEm  DateTime?
  emailVerificacaoEnviadoEm DateTime?
  medico    Medico?
  paciente  Paciente?
  deviceTokens DeviceToken[]
  refreshTokens RefreshToken[]
  accessTokenBlocklist AccessTokenBlocklist[]
  passwordResetTokens PasswordResetToken[]
  criadoEm  DateTime @default(now())
}

enum TipoUsuario {
  PACIENTE
  MEDICO
  ADMIN
}

model Medico {
  id             String   @id @default(uuid())
  usuarioId      String   @unique
  crm            String
  especialidades String[]
  aprovado       Boolean  @default(false)
  documentos     Documento[]
  consultas      Consulta[]
  avaliacoes     Avaliacao[]
  usuario        Usuario   @relation(fields:[usuarioId], references:[id])
}

model Paciente {
  id        String @id @default(uuid())
  usuarioId String @unique
  usuario   Usuario @relation(fields:[usuarioId], references:[id])
  consultas Consulta[]
  avaliacoes Avaliacao[]
}

model Consulta {
  id         String   @id @default(uuid())
  medicoId   String
  pacienteId String
  data       DateTime
  motivo     String
  status     StatusConsulta @default(PENDENTE)
  meetLink   String?
  lembrete15mEnviado   Boolean  @default(false)
  lembreteDiarioEnviado Boolean @default(false)
  emailAvaliacaoEnviado Boolean @default(false)
  cancelTokenHash       String?
  cancelTokenExpiraEm   DateTime?
  pagamento  Pagamento?
  avaliacao Avaliacao?
  medico     Medico   @relation(fields:[medicoId], references:[id])
  paciente   Paciente @relation(fields:[pacienteId], references:[id])
}

model Avaliacao {
  id         String   @id @default(uuid())
  consultaId String   @unique
  medicoId   String
  pacienteId String
  nota       Int
  comentario String?
  criadoEm   DateTime @default(now())

  consulta   Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  medico     Medico   @relation(fields: [medicoId], references: [id], onDelete: Cascade)
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([medicoId])
  @@index([pacienteId])
}

model Pagamento {
  id            String  @id @default(uuid())
  consultaId    String  @unique
  metodo        MetodoPagamento
  valorCentavos Int
  status        StatusPagamento @default(AGUARDANDO)
  transacaoId   String?
  consulta      Consulta @relation(fields:[consultaId], references:[id])
}

model Documento {
  id       String @id @default(uuid())
  medicoId String
  url      String
  tipo     String
  medico   Medico  @relation(fields:[medicoId], references:[id])
}

model DeviceToken {
  id        String   @id @default(uuid())
  usuarioId String
  token     String   @unique
  platform  String?
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

enum StatusConsulta {
  PENDENTE
  ACEITA
  RECUSADA
  CONCLUIDA
  CANCELADA
}

enum MetodoPagamento {
  PIX
  CARTAO
}

enum StatusPagamento {
  AGUARDANDO
  PAGO
  FALHOU
}

model RefreshToken {
  id        String   @id @default(uuid())
  usuarioId String
  tokenHash String   @unique
  criadoEm  DateTime @default(now())
  expiraEm  DateTime
  revogadoEm DateTime?

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiraEm])
}

model AccessTokenBlocklist {
  jti       String   @id
  usuarioId String
  expiraEm  DateTime
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiraEm])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  usuarioId String
  tokenHash String   @unique
  criadoEm  DateTime @default(now())
  expiraEm  DateTime
  usadoEm   DateTime?

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiraEm])
}
