generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senhaHash String
  tipo      TipoUsuario
  telefone  String?
  emailConfirmado Boolean @default(false)
  emailVerificacaoTokenHash String?
  emailVerificacaoExpiraEm  DateTime?
  emailVerificacaoEnviadoEm DateTime?
  medico    Medico?
  paciente  Paciente?
  deviceTokens DeviceToken[]
  refreshTokens RefreshToken[]
  accessTokenBlocklist AccessTokenBlocklist[]
  passwordResetTokens PasswordResetToken[]
  criadoEm  DateTime @default(now())
}

enum TipoUsuario {
  PACIENTE
  MEDICO
  ADMIN
}

enum StatusMedico {
  PENDENTE
  APROVADO
  REJEITADO
}

model Medico {
  id             String   @id @default(uuid())
  usuarioId      String   @unique
  crm            String   @unique
  especialidades String[]
  // Legado: mantido por compatibilidade (use `status` como fonte da verdade)
  aprovado       Boolean  @default(false)
  status         StatusMedico @default(PENDENTE)
  diplomaUrl     String?
  motivoRejeicao String?
  // Dados bancários / Pix
  tipoChavePix         TipoChavePix?
  valorChavePix        String?
  banco                String?
  agencia              String?
  conta                String?
  mpAccessTokenEncrypted String?
  mpUserId             String?
  // Saldo semanal (centavos)
  saldoPendente        Int      @default(0)
  saldoALiberar        Int      @default(0)
  saldoTotalRecebido   Int      @default(0)
  proximoRepasse       DateTime?
  createdAt      DateTime @default(now())
  documentos     Documento[]
  consultas      Consulta[]
  avaliacoes     Avaliacao[]
  repasses       Repasse[]
  ciclosRepasse  CicloRepasse[]
  usuario        Usuario   @relation(fields:[usuarioId], references:[id])
}

model Paciente {
  id        String @id @default(uuid())
  usuarioId String @unique
  usuario   Usuario @relation(fields:[usuarioId], references:[id])
  consultas Consulta[]
  avaliacoes Avaliacao[]
}

model Consulta {
  id         String   @id @default(uuid())
  medicoId   String
  pacienteId String
  data       DateTime
  motivo     String
  status     StatusConsulta @default(PENDENTE)
  meetLink   String?
  lembrete15mEnviado   Boolean  @default(false)
  lembreteDiarioEnviado Boolean @default(false)
  emailAvaliacaoEnviado Boolean @default(false)
  cancelTokenHash       String?
  cancelTokenExpiraEm   DateTime?
  pagamento  Pagamento?
  repasse    Repasse?
  avaliacao Avaliacao?
  medico     Medico   @relation(fields:[medicoId], references:[id])
  paciente   Paciente @relation(fields:[pacienteId], references:[id])

  @@index([pacienteId])
  @@index([medicoId])
  @@index([data])
}

model Avaliacao {
  id         String   @id @default(uuid())
  consultaId String   @unique
  medicoId   String
  pacienteId String
  nota       Int
  comentario String?
  criadoEm   DateTime @default(now())

  consulta   Consulta @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  medico     Medico   @relation(fields: [medicoId], references: [id], onDelete: Cascade)
  paciente   Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([medicoId])
  @@index([pacienteId])
}

model Pagamento {
  id            String  @id @default(uuid())
  consultaId    String  @unique
  metodo        MetodoPagamento
  valorCentavos Int
  status        StatusPagamento @default(AGUARDANDO)
  transacaoId   String? @unique
  consulta      Consulta @relation(fields:[consultaId], references:[id])
}

model MercadoPagoWebhookEvent {
  id           String   @id @default(uuid())
  eventId      String   @unique
  paymentId    String
  type         String?
  action       String?
  processado   Boolean  @default(false)
  processadoEm DateTime?
  recebidoEm   DateTime @default(now())

  @@index([paymentId])
  @@index([recebidoEm])
}

model Documento {
  id       String @id @default(uuid())
  medicoId String
  url      String
  tipo     String
  medico   Medico  @relation(fields:[medicoId], references:[id])
}

model DeviceToken {
  id        String   @id @default(uuid())
  usuarioId String
  token     String   @unique
  platform  String?
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
}

enum StatusConsulta {
  PENDENTE
  ACEITA
  RECUSADA
  CONCLUIDA
  CANCELADA
}

enum MetodoPagamento {
  PIX
  CARTAO
}

enum StatusPagamento {
  AGUARDANDO
  PAGO
  FALHOU
}

model RefreshToken {
  id        String   @id @default(uuid())
  usuarioId String
  tokenHash String   @unique
  criadoEm  DateTime @default(now())
  expiraEm  DateTime
  revogadoEm DateTime?

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiraEm])
}

model AccessTokenBlocklist {
  jti       String   @id
  usuarioId String
  expiraEm  DateTime
  criadoEm  DateTime @default(now())

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiraEm])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  usuarioId String
  tokenHash String   @unique
  criadoEm  DateTime @default(now())
  expiraEm  DateTime
  usadoEm   DateTime?

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiraEm])
}

// =====================
// DADOS BANCÁRIOS / PIX
// =====================

enum TipoChavePix {
  CPF
  CNPJ
  EMAIL
  TELEFONE
  ALEATORIA
}

// =====================
// REPASSE (SPLIT DE PAGAMENTO)
// =====================

enum StatusRepasse {
  PENDENTE
  PROCESSADO
  FALHOU
}

model Repasse {
  id            String        @id @default(uuid())
  consultaId    String        @unique
  medicoId      String
  valorBruto    Int
  taxaApp       Int
  valorRepasse  Int
  status        StatusRepasse @default(PENDENTE)
  dataRepasse   DateTime?
  cicloRepasseId String?
  criadoEm      DateTime      @default(now())

  consulta      Consulta      @relation(fields: [consultaId], references: [id])
  medico        Medico        @relation(fields: [medicoId], references: [id])
  cicloRepasse  CicloRepasse? @relation(fields: [cicloRepasseId], references: [id])

  @@index([medicoId])
  @@index([status])
  @@index([cicloRepasseId])
}

// =====================
// LOG DE NOTIFICAÇÕES
// =====================

enum CanalNotificacao {
  EMAIL
  PUSH
  WHATSAPP
}

model NotificacaoLog {
  id          String           @id @default(uuid())
  consultaId  String?
  usuarioId   String
  canal       CanalNotificacao
  tipoEvento  String
  status      String           @default("ENVIADO")
  enviadoEm   DateTime         @default(now())

  @@index([consultaId])
  @@index([usuarioId])
  @@index([enviadoEm])
}

// =====================
// CICLO DE REPASSE SEMANAL
// =====================

enum StatusCicloRepasse {
  PENDENTE
  PROCESSANDO
  CONCLUIDO
  ERRO
}

model CicloRepasse {
  id               String              @id @default(uuid())
  medicoId         String
  semanaInicio     DateTime
  semanaFim        DateTime
  valorBruto       Int                 @default(0)
  taxaApp          Int                 @default(0)
  valorRepasse     Int                 @default(0)
  status           StatusCicloRepasse  @default(PENDENTE)
  dataProcessamento DateTime?
  mpPaymentId      String?
  erroMsg          String?
  criadoEm         DateTime            @default(now())

  medico           Medico              @relation(fields: [medicoId], references: [id])
  repasses         Repasse[]

  @@unique([medicoId, semanaInicio])
  @@index([medicoId])
  @@index([status])
  @@index([semanaInicio])
}
