# =====================
# DATABASE
# =====================
DATABASE_URL="postgresql://usuario:senha@SEU_POSTGRES_HOST:5432/sejaatendido?schema=public"
# Opcional: mantido para compatibilidade (não é mais exigido pelo schema Prisma)
DIRECT_URL="postgresql://usuario:senha@SEU_POSTGRES_HOST:5432/sejaatendido"

# =====================
# MONGODB (CHAT - opcional)
# =====================
MONGODB_URI="mongodb+srv://usuario:senha@SEU_CLUSTER.mongodb.net/sejaatendido?retryWrites=true&w=majority"
# Se true, falha ao conectar derruba o processo (default: false)
MONGODB_REQUIRED="false"

# =====================
# JWT
# =====================
# IMPORTANTE: Altere isso em produção!
JWT_SEGREDO="sua-chave-secreta-super-segura-aqui"

# Tempo de vida do access token (JWT) em minutos
JWT_ACCESS_TOKEN_MINUTOS=15

# Tempo de vida do refresh token em dias
JWT_REFRESH_TOKEN_DIAS=30

# Tempo de vida do token de reset de senha (horas)
PASSWORD_RESET_TTL_HORAS=2

# Logging
# =====================
# SERVIDOR
# =====================
NODE_ENV="development"
# Em produção (Render/Railway/etc): use PORT (fornecido pela plataforma). Localmente: use PORTA.
PORTA=3001

# =====================
# DATABASE (Postgres)
# =====================
DATABASE_URL="postgresql://usuario:senha@SEU_POSTGRES_HOST:5432/sejaatendido?schema=public"
# Opcional: mantido para compatibilidade (não é mais exigido pelo schema Prisma)
DIRECT_URL="postgresql://usuario:senha@SEU_POSTGRES_HOST:5432/sejaatendido"

# =====================
# MONGODB (CHAT - opcional)
# =====================
MONGODB_URI="mongodb+srv://usuario:senha@SEU_CLUSTER.mongodb.net/sejaatendido?retryWrites=true&w=majority"
# Se true, falha ao conectar derruba o processo (default: false)
MONGODB_REQUIRED="false"

# =====================
# CORS
# =====================
# Lista separada por vírgulas OU "*" (NÃO permitido em produção).
# Compat: pode usar CORS_ORIGINS ou CORS_ORIGIN.
CORS_ORIGINS="http://localhost:8081,http://localhost:19006,capacitor://localhost,ionic://localhost"

# =====================
# URLs públicas (usadas para links em emails e webhooks)
# =====================
# Compat: pode usar FRONTEND_URL ou FRONTEND_ORIGIN.
FRONTEND_URL="http://localhost:3000"
BACKEND_URL="http://localhost:3001"

# =====================
# JWT
# =====================
# Compat: pode usar JWT_SEGREDO ou JWT_SECRET.
JWT_SEGREDO="sua-chave-secreta-super-segura-aqui"
JWT_ACCESS_TOKEN_MINUTOS=15
JWT_REFRESH_TOKEN_DIAS=30
PASSWORD_RESET_TTL_HORAS=2

# =====================
# Logging
# =====================
LOG_LEVEL="info"

# =====================
# JOBS/CRON (opcional)
# =====================
CRON_SECRET=""
ENABLE_EMAIL_JOBS="false"

# =====================
# Google OAuth (opcional)
# =====================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =====================
# FIREBASE (Push Notifications - FCM) (opcional)
# =====================
FIREBASE_SERVICE_ACCOUNT_JSON=""
# Alternativa (útil no Render): JSON em base64 (use apenas se não conseguir colar o JSON direto)
FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=""

# =====================
# STRIPE (Pagamentos) (opcional)
# =====================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# =====================
# MERCADO PAGO (Checkout Pro) (opcional)
# =====================
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_WEBHOOK_SECRET=""

# =====================
# EMAIL (SMTP) (opcional)
# =====================
# Gmail: smtp.gmail.com / 587
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""

