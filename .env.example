# =====================
# DATABASE
# =====================
DATABASE_URL="postgresql://usuario:senha@SEU_POSTGRES_HOST:5432/sejaatendido?schema=public"
DIRECT_URL="postgresql://usuario:senha@SEU_POSTGRES_HOST:5432/sejaatendido"

# =====================
# MONGODB (CHAT - opcional)
# =====================
MONGODB_URI="mongodb+srv://usuario:senha@SEU_CLUSTER.mongodb.net/sejaatendido?retryWrites=true&w=majority"

# =====================
# JWT
# =====================
# IMPORTANTE: Altere isso em produção!
JWT_SEGREDO="sua-chave-secreta-super-segura-aqui"

# Tempo de vida do access token (JWT) em minutos
JWT_ACCESS_TOKEN_MINUTOS=15

# Tempo de vida do refresh token em dias
JWT_REFRESH_TOKEN_DIAS=30

# Tempo de vida do token de reset de senha (horas)
PASSWORD_RESET_TTL_HORAS=2

# Logging
LOG_LEVEL="info"

# =====================
# SERVIDOR
# =====================
PORTA=3001
NODE_ENV="development"

# =====================
# CORS
# =====================
# Use o domínio do seu frontend web (se tiver). Em app mobile (Expo nativo), CORS não é aplicado.
CORS_ORIGIN="https://SEU_FRONTEND_DOMINIO"

# =====================
# JOBS/CRON (opcional)
# =====================
# Use para proteger endpoints acionados por agendadores externos.
CRON_SECRET=""

# =====================
# Google OAuth (opcional)
# =====================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =====================
# FIREBASE (Push Notifications - FCM)
# =====================
# Opção 1: informar o JSON do service account inteiro como string
FIREBASE_SERVICE_ACCOUNT_JSON=""
# Opção 2: usar GOOGLE_APPLICATION_CREDENTIALS no ambiente do deploy apontando para um arquivo

# =====================
# STRIPE (Pagamentos)
# =====================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# =====================
# EMAIL (SMTP)
# =====================
# Gmail: smtp.gmail.com / 587
# Outlook: smtp-mail.outlook.com / 587
# SendGrid: smtp.sendgrid.net / 587
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"

# =====================
# FRONTEND
# =====================
FRONTEND_URL="https://SEU_FRONTEND_DOMINIO"

# Base URL público do BACKEND (usado para links que apontam direto para a API)
BACKEND_URL="https://sejaatendido.api.br"

# =====================
# EMAIL JOBS (CRON interno - opcional)
# =====================
# Se true, o backend roda cron jobs internos via node-cron.
ENABLE_EMAIL_JOBS="false"

# Duração padrão da consulta (usado para calcular email de avaliação)
CONSULTA_DURACAO_MINUTOS=60

# TTL dos tokens (hash no banco)
EMAIL_VERIFICACAO_TTL_HORAS=24
CANCEL_TOKEN_TTL_HORAS=24

