# =====================
# DATABASE
# =====================
DATABASE_URL="postgresql://usuario:senha@localhost:5432/sejaatendido?schema=public"

# =====================
# JWT
# =====================
# IMPORTANTE: Altere isso em produção!
JWT_SEGREDO="sua-chave-secreta-super-segura-aqui"

# =====================
# SERVIDOR
# =====================
PORTA=3001
NODE_ENV="development"

# =====================
# CORS
# =====================
CORS_ORIGIN="http://localhost:19006"

# =====================
# JOBS/CRON (opcional)
# =====================
# Use para proteger endpoints acionados por agendadores externos.
CRON_SECRET=""

# =====================
# Google OAuth (opcional)
# =====================
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =====================
# FIREBASE (Push Notifications - FCM)
# =====================
# Opção 1: informar o JSON do service account inteiro como string
FIREBASE_SERVICE_ACCOUNT_JSON=""
# Opção 2: usar GOOGLE_APPLICATION_CREDENTIALS no ambiente do deploy apontando para um arquivo

# =====================
# STRIPE (Pagamentos)
# =====================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# =====================
# EMAIL (SMTP)
# =====================
# Gmail: smtp.gmail.com / 587
# Outlook: smtp-mail.outlook.com / 587
# SendGrid: smtp.sendgrid.net / 587
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"

# =====================
# FRONTEND
# =====================
FRONTEND_URL="http://localhost:3000"

# Base URL público do BACKEND (usado para links que apontam direto para a API)
BACKEND_URL="http://localhost:3001"

# =====================
# EMAIL JOBS (CRON interno - opcional)
# =====================
# Se true, o backend roda cron jobs internos via node-cron.
ENABLE_EMAIL_JOBS="false"

# Duração padrão da consulta (usado para calcular email de avaliação)
CONSULTA_DURACAO_MINUTOS=60

# TTL dos tokens (hash no banco)
EMAIL_VERIFICACAO_TTL_HORAS=24
CANCEL_TOKEN_TTL_HORAS=24

